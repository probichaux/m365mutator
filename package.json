{
  "name": "m365mutator",
  "version": "0.6.5",
  "description": "M365Mutator — logs into a Microsoft 365 tenant via Microsoft Graph and mutates users, mail, calendar items, and OneDrive/SharePoint documents.",
  "license": "MIT",
  "author": "Paul Robichaux",
  "main": "./build/main.js",
  "type": "module",
  "keywords": [
    "microsoft-graph",
    "microsoft-365",
    "entra-id",
    "sharepoint",
    "onedrive"
  ],
  "scripts": {
    "prestart": "lsof -ti :${PORT:-3700} | xargs kill 2>/dev/null || true",
    "start": "node build/main.js",
    "build": "tsc && vite build --config src/admin/client/vite.config.ts",
    "build:watch": "tsc --watch",
    "dev": "./dev.sh",
    "test": "vitest run"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "docx": "^9.7.1",
    "dotenv": "^16.5.0",
    "express": "5.1.0",
    "helmet": "^8.1.0",
    "markdownlint": "^0.41.0",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@fluentui/react-components": "^9.73.7",
    "@fluentui/react-icons": "^2.0.230",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "i18next": "^25.8.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.5.4",
    "typescript": "5.8.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
