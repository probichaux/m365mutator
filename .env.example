# Required: Microsoft Graph (Entra ID app registration)
GRAPH_CLIENT_ID=
GRAPH_TENANT_ID=

# Graph authentication: use EITHER client secret OR certificate (not both)
GRAPH_CLIENT_SECRET=
# GRAPH_CERTIFICATE_PATH=          # Path to PEM file with cert + private key
# GRAPH_CERTIFICATE_PASSWORD=      # Optional password for encrypted PEM
# GRAPH_SEND_CERTIFICATE_CHAIN=    # Set to 'true' for x5c claim (SNI auth)

# The app registration needs application (not delegated) permissions, admin-consented,
# for whichever mutations this tool will perform, e.g.:
#   User.ReadWrite.All            — update users
#   Mail.ReadWrite, Mail.Send     — create/reply to mail messages
#   Calendars.ReadWrite           — create/update calendar items
#   Files.ReadWrite.All           — OneDrive documents
#   Sites.ReadWrite.All           — SharePoint documents

# Optional
PORT=3700
M365MUTATOR_LOG_PATH=

# The admin UI has no login — anyone who can reach it can read/change this
# config and drive Graph operations. Run it somewhere only trusted operators
# can reach. Config (including Graph secrets, stored as plaintext) is
# persisted under this directory with owner-only file permissions.
M365MUTATOR_DATA_DIR=/data
